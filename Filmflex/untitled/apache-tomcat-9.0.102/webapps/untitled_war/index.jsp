<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset="utf-8" />
    <link rel="stylesheet" href="globals.css" />
    <link rel="stylesheet" href="styleguide.css" />
    <link rel="stylesheet" href="style.css" />
</head>
<body>
<div class="desktop">
    <div class="slingshot-wrapper">
        <div class="slingshot">
            <img class="pattern" src="img/pattern-2.png" />
            <div class="overlap">
                <div class="overlap-group">
                    <p class="title">FIND THE PERFECT TUTOR FOR YOU<br />ANYTIME, ANYWHERE!</p>
                    <div class="img-pattern">
                        <div class="play"><img class="polygon" src="img/polygon.svg" /></div>
                    </div>
                    <img class="image" src="img/image-um5zotw7r-transformed-1.png" />
                    <div class="group">
                        <div class="group-wrapper"><img class="img" src="img/group-8.png" /></div>
                    </div>
                </div>
                <div class="overlap-wrapper">
                    <div class="div">
                        <div class="overlap-2">
                            <div class="text-wrapper">250k</div>
                            <div class="text-wrapper-2">Assisted Student</div>
                        </div>
                        <div class="calendar-wrapper">
                            <div class="calendar">
                                <div class="group-2"></div>
                                <div class="group-3"></div>
                                <div class="overlap-group-2">
                                    <div class="group-4"></div>
                                    <div class="group-5"></div>
                                    <div class="group-6"></div>
                                    <div class="group-7"></div>
                                    <div class="group-8"></div>
                                    <div class="group-9"></div>
                                    <div class="group-10"></div>
                                    <div class="group-11"></div>
                                    <div class="group-12"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <header class="header">
                <div class="logo">SmartTutor</div>
                <div class="menu">
                    <div class="text-wrapper-3">Benefits</div>
                    <div class="text-wrapper-3">About</div>
                    <div class="text-wrapper-3">FAQ</div>
                </div>
                <div class="action">
                    <div class="button-log-in"><div class="label">Log In</div></div>
                    <div class="button-get-started">
                        <p class="p"><span class="span">Get started</span> <span class="text-wrapper-4"> it’s free</span></p>
                    </div>
                </div>
            </header>
            <div class="frame">
                <div class="overlap-group-3">
                    <img class="vector" src="img/image.svg" />
                    <img class="vector-2" src="img/vector-2.svg" />
                    <img class="vector-3" src="img/vector.svg" />
                    <img class="group-13" src="img/group-4.png" />
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>