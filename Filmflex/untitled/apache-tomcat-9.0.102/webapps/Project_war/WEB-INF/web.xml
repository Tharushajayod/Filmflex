<web-app
        xmlns="http://xmlns.jcp.org/xml/ns/javaee"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
    http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
        version="4.0">

  <display-name>Smart Tutor</display-name>

  <!-- Welcome file configuration -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>login.jsp</welcome-file>
  </welcome-file-list>

  <!-- Register Servlet Configuration -->
  <servlet>
    <servlet-name>RegisterServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.RegisterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>RegisterServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <!-- Sign In Servlet Configuration -->
  <servlet>
    <servlet-name>SignInServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.SignInServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>SignInServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>UpdateStudentDetailsServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.UpdateStudentDetailsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UpdateStudentDetailsServlet</servlet-name>
    <url-pattern>/student/updateStudentDetails</url-pattern>
  </servlet-mapping>






  <servlet>
    <servlet-name>UpdateUserDetailsServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.UpdateUserDetailsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UpdateUserDetailsServlet</servlet-name>
    <url-pattern>/updateUserDetails</url-pattern>
  </servlet-mapping>


  <servlet>
    <servlet-name>AdminDashboardServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.AdminDashboardServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>AdminDashboardServlet</servlet-name>
    <url-pattern>/admin/userlist</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>TeacherServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.TeacherServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>TeacherServlet</servlet-name>
    <url-pattern>/teacher</url-pattern>
  </servlet-mapping>


  <!-- Mapping for DeleteUserServlet -->
  <servlet>
    <servlet-name>DeleteUserServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.DeleteUserServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>DeleteUserServlet</servlet-name>
    <url-pattern>/admin/deleteUser</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>EditUserServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.EditUserServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>EditUserServlet</servlet-name>
    <url-pattern>/admin/editUser</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AddSubjectServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.AddSubjectServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AddSubjectServlet</servlet-name>
    <url-pattern>/tutor/addSubject</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AddTutorServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.AddTutorServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AddTutorServlet</servlet-name>
    <url-pattern>/addTutor</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ViewTutorsServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.ViewTutorsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ViewTutorsServlet</servlet-name>
    <url-pattern>/viewTutors</url-pattern>
  </servlet-mapping>


  <servlet>
    <servlet-name>DeleteSubjectServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.DeleteSubjectServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>DeleteSubjectServlet</servlet-name>
    <url-pattern>/deleteSubject</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>EditSubjectServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.EditSubjectServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>EditSubjectServlet</servlet-name>
    <url-pattern>/editSubject</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>UpdateSubjectServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.UpdateSubjectServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UpdateSubjectServlet</servlet-name>
    <url-pattern>/updateSubject</url-pattern>
  </servlet-mapping>


  <servlet>
    <servlet-name>TutorDashboardServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.TutorDashboardServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>TutorDashboardServlet</servlet-name>
    <url-pattern>/tutor-dashboard</url-pattern>
  </servlet-mapping>


  <servlet>
    <servlet-name>BookLessonServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.BookLessonServlet</servlet-class>
  </servlet>

  <!-- Servlet Mapping -->
  <servlet-mapping>
    <servlet-name>BookLessonServlet</servlet-name>
    <url-pattern>/bookLesson</url-pattern>
  </servlet-mapping>

  <!-- Servlet for Edit Booking -->
  <servlet>
    <servlet-name>EditBookingServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.EditBookingServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>EditBookingServlet</servlet-name>
    <url-pattern>/editBooking</url-pattern>
  </servlet-mapping>



  <!-- Servlet for Cancel Booking -->
  <servlet>
    <servlet-name>CancelBookingActionServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.CancelBookingActionServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>CancelBookingActionServlet</servlet-name>
    <url-pattern>/cancelBookingAction</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>PaymentServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.PaymentServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>PaymentServlet</servlet-name>
    <url-pattern>/payment</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ViewPaymentsServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.ViewPaymentsServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ViewPaymentsServlet</servlet-name>
    <url-pattern>/viewPayments</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>EditPaymentServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.EditPaymentServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>EditPaymentServlet</servlet-name>
    <url-pattern>/editPayment</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>DeletePaymentServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.DeletePaymentServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>DeletePaymentServlet</servlet-name>
    <url-pattern>/deletePayment</url-pattern>
  </servlet-mapping>


  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.Smarttutor.servlet.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>




</web-app>
